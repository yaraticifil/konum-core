rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'gumussalimm@gmail.com';
    }

    // Drivers
    match /drivers/{driverId} {
      allow read: if isOwner(driverId) || isAdmin();
      allow write: if isOwner(driverId) || isAdmin();
    }

    // Passengers
    match /passengers/{passengerId} {
      allow read: if isOwner(passengerId) || isAdmin();
      allow write: if isOwner(passengerId) || isAdmin();
    }

    // Rides
    match /rides/{rideId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (
        resource.data.passengerId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );
      allow update: if isAuthenticated() && (
        resource.data.passengerId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      ) && (
        !("legalHash" in resource.data) ||
        request.resource.data.legalHash == resource.data.legalHash
      );
    }

    // Insurance
    match /insurance_policies/{policyId} {
      allow read: if isAuthenticated() && (
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated();
    }

    // Driver Locations
    match /driver_locations/{driverId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(driverId);
    }

    // System logs, invoices, hub owners (from upstream)
    match /system_logs/{logId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
    }
    match /invoices/{invoiceId} {
      allow read: if isAuthenticated() && (
        resource.data.passengerId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated();
    }
    match /hub_owners/{ownerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
